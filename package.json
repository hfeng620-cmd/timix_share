    "@supabase/supabase-js": "^2.108.2",
    "emoji-picker-react": "^4.19.1",
    "hls.js": "^1.6.16",
    "lucide-react": "^0.462.0",
    "motion": "^12.42.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "three": "^0.185.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
