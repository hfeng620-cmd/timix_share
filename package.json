{
  "name": "api-test-and-forum",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "start:named-tunnel": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start-timin-named-tunnel.ps1",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "mobile:build": "next build && node scripts/flatten-mobile-css.mjs && cap sync android",
    "mobile:android": "npm run mobile:build && cap open android",
    "mobile:apk:debug": "npm run mobile:build && cd android && gradlew assembleDebug",
    "mobile:apk:release": "npm run mobile:build && cd android && gradlew assembleRelease",
    "mobile:check": "powershell -ExecutionPolicy Bypass -File .\\scripts\\check-android-env.ps1"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.1",
    "@capacitor/local-notifications": "^8.2.0",
